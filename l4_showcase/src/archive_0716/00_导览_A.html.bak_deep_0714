STAGES.forEach((s,i)=>{const b=document.createElement('button');b.className='stage-btn';b.innerHTML=`<span class="no">${s.n}</span><b>${s.t}</b><small>${s.s}</small>`;b.onclick=()=>selectStage(i);pipe.appendChild(b)});selectStage(0);
