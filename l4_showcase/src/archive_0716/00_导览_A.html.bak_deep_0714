function copyText(t){if(navigator.clipboard)return navigator.clipboard.writeText(t).catch(()=>fallback(t));return fallback(t);function fallback(x){const ta=document.createElement('textarea');ta.value=x;document.body.appendChild(ta);ta.select();document.execCommand('copy');ta.remove()}}
