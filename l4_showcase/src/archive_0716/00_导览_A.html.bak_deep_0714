  <section class="statement" id="statement"><b>证据边界</b><p>仿真指标统一标注（sim）。物理部分是 Factory I/O 54 位代表性技术预演；H5 9/9 表示全链取放在当前 work 场景运行成功，Target 恢复仅作为下放成功的必要操作条件，不外推为系统级安全结论。F5 二审已结案：编译加载级可行，但当前 VirtualAC500 实例主站直驱不可用（当前环境负结果，非全产品线定理），真机 AC500 / 软 PLC 路线待做。5-seed 的 8.40±0.48 s 仅作回归锚，与本页 30-seed 泛化主证分工独立。</p></section>
</div><div id="toast">路径已复制</div>
<script>
const STAGES=[
 {n:'01',t:'建模与仿真',s:'几何、约束、运动学',d:'以 20×20 单排货架、单巷道单堆垛机为对象，行程时间采用双轴同动的切比雪夫模型；报告主口径启用梯形加减速。',e:'A1–A5 · C12\npython sim/final_test_30seed.py'},
 {n:'02',t:'布局优化算法',s:'AWRA-LS 与策略库',d:'在可行性优先的约束门下比较货位策略；30-seed 泛化主证与 390 个可比实例的算法选择结果均来自 sim。',e:'AWRA-LS / CB / TOB\n98.5% on comparable cases (sim)'},
 {n:'03',t:'PLC 工程实现',s:'AC500 ST 核心逻辑',d:'核心分配、策略、守卫与测试代码已进入 ST 工程；75/0 的证据级别限定为 AB PC 仿真编译与在线回读。',e:'canonical C11\nCompile 0 errors · 75 passed / 0 failed'},
 {n:'04',t:'三页制 HMI',s:'操作、记录、管理',d:'P1 负责日常操作，P2 承载追溯与查询，P3 放置配置与诊断；地图支持 8 态色码、分层寻址和三态视图。',e:'3 pages · 21 interactions\nstatus / frequency / operation heatmap'},
 {n:'05',t:'代表性技术预演',s:'Factory I/O 54 位',d:'H5 全链取放 9/9 运行成功；结论限于当前 work 场景。该层验证三维动作与 I/O 时序，不替代 20×20 逻辑模型。',e:'H5 9/9 runtime success\n54-slot representative preview'}];
const MATS=[
 ['01','验证报告','WORD 正文与 PPT 评审快览，覆盖方法、统计、工程证据与边界。','01_验证报告/'],
 ['02','PLC 工程代码','Automation Builder 工程、ST 源码导出、黄金向量与测试证据。','02_PLC代码/'],
 ['03','建模与仿真','Python 源码、关键 CSV/图与一键复现入口。','03_建模与仿真/'],
 ['04','可视化仿真','Three.js 展示源码、三维轨迹回放与演示录屏。','04_可视化仿真_决赛件/'],
 ['05','技术预演素材','Factory I/O 全链取放记录与 54 位场景说明。','05_物理预演素材_加分/'],
 ['TXT','README','任意环境可读的纯文本导览与目录说明。','README.md']];
const MODS=[
