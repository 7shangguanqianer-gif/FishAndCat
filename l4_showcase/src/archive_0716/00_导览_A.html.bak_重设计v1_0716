MODULES.forEach(function(m,i){const b=document.createElement('button');b.type='button';b.className='module'+(i===0?' selected':'');
const ok=m[4]!=='规划中';
b.innerHTML='<span class="id">'+m[0]+'</span><span><b>'+m[1]+'</b><small class="'+(ok?'ok':'')+'">'+(ok?'● ':'○ ')+m[4]+'</small></span>';
b.onclick=function(){document.querySelectorAll('.module').forEach(function(x){x.classList.remove('selected')});b.classList.add('selected');
