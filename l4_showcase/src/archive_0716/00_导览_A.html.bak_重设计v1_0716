moduleGrid.appendChild(b)});
const materialGrid=document.getElementById('materialGrid');
MATERIALS.forEach(function(m,i){const b=document.createElement('button');b.type='button';b.className='material-row'+(i===0?' selected':'');
b.innerHTML='<span class="id">'+m[0]+'</span><span><b>'+m[1]+'</b><span>'+m[2]+'</span></span>';
b.onclick=function(){showMaterial(m,true)};materialGrid.appendChild(b)});
selectedMaterial=MATERIALS[0];
function fullPath(rel){try{const u=new URL(rel,location.href);return decodeURIComponent(u.pathname).replace(/^\/([A-Za-z]:)/,'$1').replace(/\//g,'\\')}catch(_){return rel}}
function showMaterial(m,mark){if(mark===undefined)mark=true;selectedMaterial=m;
if(mark){document.querySelectorAll('.material-row').forEach(function(x,i){x.classList.toggle('selected',MATERIALS[i]===m)})}
const path=fullPath(m[3]);document.getElementById('materialOpen').href=m[3];
applyEvidence(['EVIDENCE · 06',m[1],'本地交付材料',m[2],[path],'材料打开后按文内标注区分 sim、控制器测试与代表性技术预演。'])}
function copyText(t){if(navigator.clipboard)return navigator.clipboard.writeText(t).catch(function(){return fallback(t)});return fallback(t);
function fallback(x){const ta=document.createElement('textarea');ta.value=x;document.body.appendChild(ta);ta.select();document.execCommand('copy');ta.remove()}}
document.getElementById('copyPath').onclick=function(){copyText(fullPath(selectedMaterial[3]));const t=document.getElementById('toast');t.style.opacity=1;setTimeout(function(){t.style.opacity=0},1200)};
addEventListener('hashchange',function(){const m=location.hash.match(/^#\/(.+)$/);setChapter(m?m[1]:'overview',false)});
const initial=location.hash.match(/^#\/(.+)$/);setChapter(initial?initial[1]:'overview',false);
