if(writeHash&&location.hash!=='#/'+id)location.hash='/'+id}
tabs.forEach(function(t,i){t.addEventListener('click',function(){setChapter(t.dataset.id)});t.addEventListener('keydown',function(e){let j=i;if(e.key==='ArrowDown'||e.key==='ArrowRight')j=(i+1)%tabs.length;else if(e.key==='ArrowUp'||e.key==='ArrowLeft')j=(i-1+tabs.length)%tabs.length;else if(e.key==='Home')j=0;else if(e.key==='End')j=tabs.length-1;else return;e.preventDefault();setChapter(tabs[j].dataset.id);tabs[j].focus()})});
